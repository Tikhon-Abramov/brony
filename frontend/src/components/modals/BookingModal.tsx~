import { useEffect, useMemo, useState } from 'react';
import { format } from 'date-fns';
import styled from 'styled-components';
import { useAppDispatch, useAppSelector } from '../../hooks/redux';
import { closeBookingModal } from '../../features/uiSlice';
import { createBooking } from '../../features/bookingsSlice';
import Select from '../../shared/ui/Select';
import {
    DAY_END_TIME,
    TIME_SLOTS,
    addMinutesToTime,
    clampStartTimeToAllowed,
    durationToMinutes,
    findBookingConflict,
    getMinStartTimeForDate,
    isDateTimeInPast,
    isDurationValid,
    isEndTimeWithinDay,
    isTimeRangeValid,
    timeToMinutes,
} from '../../utils/booking';
import {
    formatDurationInput,
    normalizeDuration,
} from '../../utils/timeMask';

export default function BookingModal() {
    const dispatch = useAppDispatch();
    const isOpen = useAppSelector((state) => state.ui.bookingModalOpen);
    const selectedDate = useAppSelector((state) => state.bookings.selectedDate);
    const selectedTime = useAppSelector((state) => state.bookings.selectedTime);
    const bookings = useAppSelector((state) => state.bookings.items);

    const [fullName, setFullName] = useState('');
    const [purpose, setPurpose] = useState('');
    const [department, setDepartment] = useState('');
    const [date, setDate] = useState(format(new Date(), 'yyyy-MM-dd'));
    const [startTime, setStartTime] = useState('10:00');
    const [duration, setDuration] = useState('00:30');
    const [error, setError] = useState('');

    const minStartTime = useMemo(() => getMinStartTimeForDate(date), [date]);

    const startTimeOptions = useMemo(() => {
        return TIME_SLOTS.filter((slot) => timeToMinutes(slot) >= timeToMinutes(minStartTime)).map(
            (slot) => ({
                value: slot,
                label: slot,
            }),
        );
    }, [minStartTime]);

    const computedEndTime = useMemo(() => {
        if (!isDurationValid(duration)) {
            return '';
        }

        return addMinutesToTime(startTime, durationToMinutes(duration));
    }, [startTime, duration]);

    useEffect(() => {
        if (!isOpen) return;

        const nextDate = selectedDate || format(new Date(), 'yyyy-MM-dd');
        const rawStartTime = selectedTime || '10:00';
        const nextStartTime = clampStartTimeToAllowed(nextDate, rawStartTime);

        setDate(nextDate);
        setStartTime(nextStartTime);
        setDuration('00:30');
        setError('');
    }, [isOpen, selectedDate, selectedTime]);

    useEffect(() => {
        setStartTime((prev) => {
            const clamped = clampStartTimeToAllowed(date, prev);
            const existsInOptions = TIME_SLOTS.includes(clamped);

            if (existsInOptions) {
                return clamped;
            }

            const firstAvailable =
                TIME_SLOTS.find((slot) => timeToMinutes(slot) >= timeToMinutes(minStartTime)) ||
                DAY_END_TIME;

            return firstAvailable;
        });
    }, [date, minStartTime]);

    if (!isOpen) return null;

    const conflict =
        computedEndTime &&
        isTimeRangeValid(startTime, computedEndTime) &&
        isEndTimeWithinDay(computedEndTime)
            ? findBookingConflict(bookings, {
                date,
                roomId: 'room-main',
                startTime,
                endTime: computedEndTime,
            })
            : undefined;

    const handleClose = () => {
        dispatch(closeBookingModal());
        setFullName('');
        setPurpose('');
        setDepartment('');
        setDate(selectedDate || format(new Date(), 'yyyy-MM-dd'));
        setStartTime(
            clampStartTimeToAllowed(
                selectedDate || format(new Date(), 'yyyy-MM-dd'),
                selectedTime || '10:00',
            ),
        );
        setDuration('00:30');
        setError('');
    };

    const handleSubmit = (e: React.FormEvent) => {
        e.preventDefault();

        if (!fullName.trim() || !purpose.trim()) {
            setError('Заполни ФИО и цель совещания');
            return;
        }

        if (!isDurationValid(duration)) {
            setError('Укажи длительность в формате ЧЧ:ММ, например 01:30');
            return;
        }

        if (timeToMinutes(startTime) < timeToMinutes(minStartTime)) {
            setError('Время начала не может быть меньше текущего времени');
            return;
        }

        if (isDateTimeInPast(date, startTime)) {
            setError('Дата и время начала бронирования не могут быть в прошлом');
            return;
        }

        if (!computedEndTime || !isTimeRangeValid(startTime, computedEndTime)) {
            setError('Проверь длительность бронирования');
            return;
        }

        if (!isEndTimeWithinDay(computedEndTime)) {
            setError(`Бронирование не должно выходить за пределы ${DAY_END_TIME}`);
            return;
        }

        const currentConflict = findBookingConflict(bookings, {
            date,
            roomId: 'room-main',
            startTime,
            endTime: computedEndTime,
        });

        if (currentConflict) {
            setError(
                `Этот слот пересекается с заявкой "${currentConflict.purpose}" (${currentConflict.startTime} — ${currentConflict.endTime})`,
            );
            return;
        }

        dispatch(
            createBooking({
                fullName: fullName.trim(),
                purpose: purpose.trim(),
                department: department.trim(),
                roomId: 'room-main',
                roomName: 'Конференц-зал',
                date,
                startTime,
                endTime: computedEndTime,
            }),
        );

        handleClose();
    };

    return (
        <Overlay onClick={handleClose}>
            <ModalCard onClick={(e) => e.stopPropagation()}>
                <Top>
                    <HeaderBlock>
                        <Title>Забронировать переговорную</Title>
                        <Subtitle>
                            Выбери дату, время начала и длительность. Заявка уйдёт на согласование.
                        </Subtitle>
                    </HeaderBlock>

                    <CloseButton type="button" onClick={handleClose} aria-label="Закрыть">
                        ✕
                    </CloseButton>
                </Top>

                <Form onSubmit={handleSubmit}>
                    <Field>
                        <Label htmlFor="booking-full-name">ФИО</Label>
                        <Input
                            id="booking-full-name"
                            value={fullName}
                            onChange={(e) => setFullName(e.target.value)}
                            placeholder="Например, Алексей Смирнов"
                        />
                    </Field>

                    <Field>
                        <Label htmlFor="booking-purpose">Цель встречи</Label>
                        <Input
                            id="booking-purpose"
                            value={purpose}
                            onChange={(e) => setPurpose(e.target.value)}
                            placeholder="Например, Планёрка команды"
                        />
                    </Field>

                    <Field>
                        <Label htmlFor="booking-department">Отдел</Label>
                        <Input
                            id="booking-department"
                            value={department}
                            onChange={(e) => setDepartment(e.target.value)}
                            placeholder="Например, Маркетинг"
                        />
                    </Field>

                    <DoubleGrid>
                        <Field>
                            <Label htmlFor="booking-date">Дата</Label>
                            <Input
                                id="booking-date"
                                type="date"
                                value={date}
                                min={format(new Date(), 'yyyy-MM-dd')}
                                onChange={(e) => {
                                    setDate(e.target.value);
                                    setError('');
                                }}
                            />
                        </Field>

                        <Field>
                            <Label htmlFor="booking-start-time">Время начала</Label>
                            <Select
                                id="booking-start-time"
                                value={startTime}
                                onChange={(value) => {
                                    setStartTime(value);
                                    setError('');
                                }}
                                options={startTimeOptions}
                                placeholder="Выбрать время"
                            />
                        </Field>
                    </DoubleGrid>

                    <Field>
                        <Label htmlFor="booking-duration">Длительность бронирования</Label>
                        <Input
                            id="booking-duration"
                            type="text"
                            inputMode="numeric"
                            value={duration}
                            onChange={(e) => {
                                setDuration(formatDurationInput(e.target.value));
                                setError('');
                            }}
                            onBlur={() => setDuration(normalizeDuration(duration))}
                            placeholder="Например, 01:30"
                        />
                        <HelperText>
                            Формат: ЧЧ:ММ. Например, 00:30, 01:00 или 02:30.
                        </HelperText>
                    </Field>

                    {computedEndTime && isDurationValid(duration) && (
                        <InfoBox>
                            Интервал бронирования: <strong>{startTime}</strong> —{' '}
                            <strong>{computedEndTime}</strong>
                        </InfoBox>
                    )}

                    {computedEndTime && !isEndTimeWithinDay(computedEndTime) && (
                        <ErrorText>
                            Бронирование не должно выходить за пределы {DAY_END_TIME}
                        </ErrorText>
                    )}

                    {conflict && (
                        <WarningBox>
                            Этот интервал уже занят: {conflict.purpose} · {conflict.startTime} —{' '}
                            {conflict.endTime}
                        </WarningBox>
                    )}

                    {error && <ErrorText>{error}</ErrorText>}

                    <Actions>
                        <GhostButton type="button" onClick={handleClose}>
                            Отмена
                        </GhostButton>

                        <PrimaryButton type="submit">
                            Отправить заявку
                        </PrimaryButton>
                    </Actions>
                </Form>
            </ModalCard>
        </Overlay>
    );
}

